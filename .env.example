# Nhentai Downloader 环境变量配置
# 复制此文件为 .env 并填入你的配置

# === 必填 ===
# nhentai.net API Key（从 https://nhentai.net/settings/ 获取）
# 格式: nhk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export NHENTAI_API_KEY="nhk_YOUR_API_KEY_HERE"

# === 可选 ===
# SOCKS5 代理地址（如果你需要代理才能访问 nhentai.net）
# 格式: socks5://127.0.0.1:10808
# export HTTP_PROXY="socks5://你的代理地址"
# export HTTPS_PROXY="socks5://你的代理地址"
